  <property name="windowTitle">
   <string>Smart Expense Manager</string>
  </property>
  <property name="styleSheet">
   <string notr="true">
    /* Tổng thể */
    QMainWindow, QStackedWidget { background-color: #f4f6f9; }

    /* Sidebar */
    QFrame#frame_sidebar { background-color: #1e272e; border-right: 1px solid #dcdde1; }
    QPushButton {
        background-color: transparent; color: #bdc3c7; border: none; border-radius: 8px;
        padding: 15px 20px; font-family: &quot;Segoe UI&quot;; font-size: 15px; text-align: left; font-weight: 500;
    }
    QPushButton:hover { background-color: #353b48; color: white; }
    QPushButton:focus { background-color: #0fb9b1; color: white; font-weight: bold; }

    /* Cards */
    QFrame[objectName^=&quot;card_&quot;] { background-color: white; border-radius: 12px; border: 1px solid #e1e4e8; }
    QLabel#label_balance_val, QLabel#lbl_prediction_result { color: #0fb9b1; font-weight: bold; font-size: 24px; }
    QLabel#label_income_val { color: #20bf6b; font-weight: bold; font-size: 20px; }
    QLabel#label_spent_val { color: #eb3b5a; font-weight: bold; font-size: 20px; }

    /* Table */
    QTableWidget { background-color: white; border-radius: 10px; gridline-color: #f1f2f6; border: 1px solid #d1d8e0; font-size: 13px;}
    QHeaderView::section { background-color: #2f3640; color: white; padding: 12px; font-weight: bold; border: none; }

    /* Form &amp; Inputs */
    QLineEdit, QDateEdit, QComboBox { border: 2px solid #d1d8e0; border-radius: 8px; padding: 10px; background: white; font-size: 14px;}
    QLineEdit:focus, QComboBox:focus { border: 2px solid #0fb9b1; }
    QPushButton#btn_save { background-color: #20bf6b; color: white; font-weight: bold; border-radius: 8px; min-height: 45px; font-size: 15px;}
    QPushButton#btn_save:hover { background-color: #26de81; }

    /* Buttons in History */
    QPushButton#btn_filter { background-color: #4b6584; color: white; border-radius: 8px; font-weight: bold; padding: 10px 20px;}
    QPushButton#btn_filter:hover { background-color: #778ca3; }

    /* AI Button */
    QPushButton#btn_analyze_ai { background-color: #8e44ad; color: white; font-weight: bold; border-radius: 8px; min-height: 45px; font-size: 16px; margin-top: 5px;}
    QPushButton#btn_analyze_ai:hover { background-color: #9b59b6; }

    /* AI Advice Card */
    QFrame#card_ai_advice { background-color: #e8f8f5; border: 1px solid #1abc9c; border-left: 6px solid #1abc9c; border-radius: 8px; }
    QLabel#lbl_ai_advice { color: #16a085; font-size: 15px; font-style: italic; }

    /* Input Text Colors */
    QLineEdit, QDateEdit, QComboBox, QTableWidget {
        color: black;
        background-color: white;
        border: 2px solid #d1d8e0;
        border-radius: 8px;
    }

    QRadioButton {
        color: black;
    }
   </string>
